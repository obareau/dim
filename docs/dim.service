[Unit]
Description=D.I.M — Dawless Is More performance sequencer
After=network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/dim
ExecStart=/home/pi/dim/.venv/bin/dim formats/my_show.json --port 5001 --host 0.0.0.0
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
Environment=PYTHONPATH=/home/pi/dim

[Install]
WantedBy=multi-user.target
